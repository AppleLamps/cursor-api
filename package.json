{
  "name": "api-for-cursor-windows",
  "version": "0.1.0",
  "type": "module",
  "description": "Electron tray app — local OpenAI-compatible API for Cursor Composer on Windows",
  "main": "dist/main.js",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AppleLamps/cursor-api.git"
  },
  "homepage": "https://github.com/AppleLamps/cursor-api#readme",
  "bugs": {
    "url": "https://github.com/AppleLamps/cursor-api/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "postinstall": "npm install --prefix vendor/composer-api",
    "vendor:prepare": "npm run db:migrate:local --prefix vendor/composer-api",
    "test": "npm run build && node --test test/*.test.mjs",
    "smoke": "npm run build && electron dist/smoke-main.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^35.0.0",
    "typescript": "^5.9.3"
  }
}
